# Copy to .env and fill in. Use the same names in Azure Container Apps (Secrets + env).
# ACS: set either ACS_CONNECTION_STRING or AZURE_COMM_CONNECTION_STRING (not both required).
# Cosmos account: set COSMOS_DB_ENDPOINT + COSMOS_DB_KEY (or legacy COSMOS_ENDPOINT / COSMOS_KEY).

# ── App ─────────────────────────────────────────────────
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=replace-with-long-random-string
LOG_LEVEL=INFO
DEBUG=false
MAX_CALL_DURATION_SECONDS=1800

# Public URL of this API (Container App HTTPS URL) — webhooks / ACS callbacks
ACS_CALLBACK_BASE_URL=https://your-app.azurecontainerapps.io

# ── Azure Communication Services ──────────────────────
ACS_CONNECTION_STRING=endpoint=https://<acs>.communication.azure.com/;accesskey=<key>
AZURE_COMM_SENDER_EMAIL=DoNotReply@<acs>.azurecomm.net
SENDGRID_API_KEY=

# ── Azure OpenAI ───────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-08-01-preview
USE_LOCAL_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# Optional: public OpenAI API if Azure OpenAI is not configured
OPENAI_API_KEY=

# Optional: POST intent + user_text + call_id after each classification (else skipped)
INTENT_SERVICE_URL=
INTENT_SERVICE_API_KEY=

# ── Azure AI Search (optional, if RAG uses Search) ─────
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=insurance-policies

# ── Azure Cosmos DB ───────────────────────────────────
# Azure Container Apps: env var NAMES may only use a-z, A-Z, 0-9, underscore (no hyphens).
# Use these in the portal:
COSMOS_DB_ENDPOINT=https://<account>.documents.azure.com:443/
# Prefer double-quoted value so trailing base64 "=" padding is preserved.
COSMOS_DB_KEY=""
# Optional: paste full string from Keys (Primary connection string) instead of endpoint+key:
# COSMOS_DB_CONNECTION_STRING=AccountEndpoint=https://...;AccountKey=...;
COSMOS_DB_DATABASE=voice_navigator
# If Cosmos fails: ensure Windows User/System env is not overriding with a placeholder (e.g. COSMOS_DB_KEY=secret).
COSMOS_DB_CONTAINER_TEMPLATES=response_templates
# Local .env only (hyphens — not valid on Container Apps): cosmos-db-endpoint, cosmos-db-key, …
COSMOS_DB_SESSION_TTL_SECONDS=3600
# Optional: separate DB for policy/identity reads; if unset, defaults to COSMOS_DB_DATABASE
COSMOS_DATABASE=
COSMOS_CONTAINER=policyholders

# ── Azure Blob (RAG documents) ─────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_DOCS=voice-nav-docs

# ── ChromaDB (use a reachable host in Azure) ──────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./chroma_data

# ── Azure Speech ───────────────────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=en-US

# ── Azure Cognitive (multi-service endpoint if needed) ─
AZURE_COGNITIVE_ENDPOINT=

# ── External intent API ────────────────────────────────
INTENT_SERVICE_URL=
INTENT_SERVICE_API_KEY=

# ── ElevenLabs ─────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2

# ── Twilio (optional) ─────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
USE_TWILIO_LOOKUP=false

# ── Genesys (optional) ────────────────────────────────
GENESYS_CLIENT_ID=
GENESYS_CLIENT_SECRET=
GENESYS_ENVIRONMENT=mypurecloud.com
GENESYS_QUEUE_ID=
GENESYS_VIP_QUEUE_ID=

# ── RAG / intent tuning ───────────────────────────────
INTENT_CONFIDENCE_THRESHOLD=0.75
RAG_TOP_K_CHUNKS=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
SUMMARY_MAX_TOKENS=500

# ── CI / local Azure CLI only (not required in Container App) ──
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_RESOURCE_GROUP=
