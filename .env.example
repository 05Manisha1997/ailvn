# ──────────────────────────────────────────────
# VOICE NAVIGATOR — ENVIRONMENT CONFIGURATION
# ──────────────────────────────────────────────
# Copy this to .env and fill in your values.
# All Azure services have free tiers for MVP.

# ── Azure Core ────────────────────────────────
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_RESOURCE_GROUP=voice-navigator-rg

# ── Azure Speech (STT + TTS) ──────────────────
# Free: 5 hrs STT/month, 500K chars TTS/month
AZURE_SPEECH_KEY=your-speech-key
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=en-US

# ── Azure OpenAI ──────────────────────────────
# Or use Ollama locally for free (set USE_LOCAL_LLM=true)
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
USE_LOCAL_LLM=false        # Set true to use Ollama (free, requires Ollama running)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral        # or llama3, phi3, etc.

# ── Azure Communication Services ─────────────
# Free: 100 emails/day, 60 min calls/month
AZURE_COMM_CONNECTION_STRING=endpoint=https://your-resource.communication.azure.com/;accesskey=xxx
AZURE_COMM_SENDER_EMAIL=DoNotReply@your-resource.azurecomm.net

# ── Azure Cosmos DB ───────────────────────────
# Free: 1000 RU/s, 25GB
COSMOS_DB_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-key
COSMOS_DB_DATABASE=voice_navigator
COSMOS_DB_CONTAINER_CALLS=calls
COSMOS_DB_CONTAINER_TEMPLATES=response_templates

# ── Azure Blob Storage ────────────────────────
# Free: 5GB
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxx
AZURE_STORAGE_CONTAINER_DOCS=voice-nav-docs

# ── Redis Cache ───────────────────────────────
# Azure Cache for Redis free tier: 250MB
# Or run locally via docker-compose
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                # Leave empty for local dev
REDIS_SSL=false
REDIS_SESSION_TTL_SECONDS=3600  # 1 hour session TTL

# ── ChromaDB ──────────────────────────────────
# Open source, runs locally or in Docker
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./chroma_data

# ── ElevenLabs TTS ───────────────────────────
# Free: 10,000 chars/month
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM  # Rachel voice (default)
ELEVENLABS_MODEL_ID=eleven_turbo_v2         # Fastest model

# ── Twilio (Phone Validation) ─────────────────
# Free: $15 trial credit (~100 lookups)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
USE_TWILIO_LOOKUP=false  # Set true to validate via Twilio API (costs ~$0.01/lookup)

# ── Genesys Cloud (Genesis) ───────────────────
# Free: 30-day trial
GENESYS_CLIENT_ID=your-genesys-client-id
GENESYS_CLIENT_SECRET=your-genesys-client-secret
GENESYS_ENVIRONMENT=mypurecloud.com
GENESYS_QUEUE_ID=your-default-queue-id
GENESYS_VIP_QUEUE_ID=your-vip-queue-id

# ── Application Settings ──────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-random-32-char-string
LOG_LEVEL=INFO
MAX_CALL_DURATION_SECONDS=1800   # 30 min max call
INTENT_CONFIDENCE_THRESHOLD=0.75
RAG_TOP_K_CHUNKS=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
SUMMARY_MAX_TOKENS=500
